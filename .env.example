# Safari Trails Africa - Environment Variables
# Copy this to .env and fill in your values

# ============================
# REQUIRED
# ============================

# MongoDB connection string (MongoDB Atlas recommended for production)
DATABASE_URL=mongodb://localhost:27017/safari-trails-africa

# Secret key for Payload CMS (minimum 32 characters, generate with: openssl rand -hex 32)
PAYLOAD_SECRET=change-this-to-a-random-string-min-32-chars

# Your website URL (no trailing slash)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ============================
# OPTIONAL
# ============================

# Cron job secret (for scheduled publishing)
CRON_SECRET=

# Email (SMTP for form submissions and notifications)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
FROM_EMAIL=info@safaritrailsafrica.com
FROM_NAME=Safari Trails Africa

# AWS S3 for media storage (recommended for production)
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=eu-west-1
S3_BUCKET=safari-trails-media

# Vercel Blob (alternative to S3)
BLOB_READ_WRITE_TOKEN=

# Preview secret for draft previews
PREVIEW_SECRET=your-preview-secret
